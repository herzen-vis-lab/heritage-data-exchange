{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "https://github.com/herzen-vis-lab/heritage-data-exchange/blob/main/schema/multilingual-string.schema.json",
  "title": "MultilingualString",
  "description": "Строка с указанием языка / Language-tagged string value",
  "type": "object",
  "required": [
    "language",
    "value"
  ],
  "properties": {
    "language": {
      "type": "string",
      "description": "BCP 47 language tag",
      "pattern": "^[a-zA-Z]{2,3}(-[a-zA-Z0-9]{2,8})*$",
      "examples": [
        "ru",
        "en",
        "de",
        "fr"
      ]
    },
    "value": {
      "type": "string",
      "minLength": 1,
      "description": "Текст на указанном языке"
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "language": "ru",
      "value": "Портрет Петра I"
    },
    {
      "language": "en",
      "value": "Portrait of Peter I"
    }
  ]
}
